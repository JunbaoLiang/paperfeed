# --- Required ---
DATABASE_URL=postgresql://user:pass@your-neon-host/paperfeed?sslmode=require
API_TOKEN=generate-a-random-string

# --- Optional ---
# Semantic Scholar API key (free; without it enrich runs at 1 req/s)
S2_API_KEY=

# Cloudflare R2 (S3-compatible) — MLflow artifacts + model files (M5+)
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# arXiv categories to ingest
ARXIV_CATEGORIES=cs.LG,cs.AI,cs.CL,stat.ML

# MLflow backend store; defaults to DATABASE_URL when unset
MLFLOW_TRACKING_URI=
